{
  "name": "scrum-docs-generator-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const src='node_modules/tinymce';const dest='public/tinymce';if(!fs.existsSync(dest)){fs.cpSync(src,dest,{recursive:true});console.log('TinyMCE copied to public folder')}\""
  },
  "dependencies": {
    "@tinymce/tinymce-react": "^6.3.0",
    "axios": "^1.6.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^6.20.0",
    "tinymce": "^8.5.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
