# Figma API Token (https://www.figma.com/developers/api#access-tokens)
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token

# GitHub Personal Access Token (https://github.com/settings/tokens)
GITHUB_TOKEN=your_github_token

# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=scrum_docs

# AI Configuration (GitHub Models)
# Seu GITHUB_TOKEN será usado para autenticação
# Modelos disponíveis: gpt-4o, gpt-4o-mini, claude-3-5-sonnet, claude-3-opus, llama-3.1-70b, mistral-large
AI_API_URL=https://models.inference.ai.azure.com
AI_MODEL=gpt-4o

# JWT Secret (gere uma string aleatória segura)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (para CORS em produção)
FRONTEND_URL=https://your-frontend.vercel.app
